# Server
PORT=3000

# PostgreSQL — Railway: copy from Railway dashboard > Variables > DATABASE_URL
# Local:   postgresql://postgres:password@localhost:5432/sugar_marina_crm
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/sugar_marina_crm

# Email (Nodemailer)
# --- Gmail ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_google_app_password
EMAIL_FROM="Sugar Marina Hotel" <your_email@gmail.com>

